    rotation: 0
    state: true
- name: mag_sq_jammed
  id: blocks_complex_to_mag_squared
  parameters:
    affinity: ''
    alias: ''
    comment: ''
    maxoutbuf: '0'
    minoutbuf: '0'
    vlen: '1'
  states:
    bus_sink: false
    bus_source: false
    bus_structure: null
    coordinate: [824, 248.0]
    rotation: 0
    state: true
- name: mixer
  id: blocks_add_xx
  parameters:
    affinity: ''
    alias: ''
    comment: ''
    maxoutbuf: '0'
    minoutbuf: '0'
    num_inputs: '2'
    type: complex
    vlen: '1'
  states:
    bus_sink: false
    bus_source: false
    bus_structure: null
    coordinate: [752, 312.0]
    rotation: 0
    state: true
- name: on_off_switch
  id: blocks_multiply_xx
  parameters:
    affinity: ''
    alias: ''
    comment: Multiplies RF by Time Control
    maxoutbuf: '0'
    minoutbuf: '0'
    num_inputs: '2'
    type: complex
    vlen: '1'
  states:
    bus_sink: false
    bus_source: false
    bus_structure: null
    coordinate: [904, 496.0]
    rotation: 0
    state: true
- name: power_scale
  id: blocks_multiply_const_vxx
  parameters:
    affinity: ''
    alias: ''
    comment: ''
    const: jammer_power
    maxoutbuf: '0'
    minoutbuf: '0'
    type: complex
    vlen: '1'
  states:
    bus_sink: false
    bus_source: false
    bus_structure: null
    coordinate: [880, 428.0]
    rotation: 0
    state: true
- name: rf_source
  id: analog_sig_source_x
  parameters:
    affinity: ''
    alias: ''
    amp: '1'
    comment: ''
    freq: jammer_freq_offset
    maxoutbuf: '0'
    minoutbuf: '0'
    offset: '0'
    phase: '0'
    samp_rate: sample_rate
    type: complex
    waveform: analog.GR_COS_WAVE
  states:
    bus_sink: false
    bus_source: false
    bus_structure: null
    coordinate: [592, 452.0]
    rotation: 0
    state: true
- name: time_slicer
  id: blocks_threshold_ff
  parameters:
    affinity: ''
    alias: ''
    comment: Output 1 only during the top fraction
    high: 1.0 - (2.0 * (on_time_min / period_total_min)) + 0.01
    init: '0'
    low: 1.0 - (2.0 * (on_time_min / period_total_min)) - 0.01
    maxoutbuf: '0'
    minoutbuf: '0'
  states:
    bus_sink: false
    bus_source: false
    bus_structure: null
    coordinate: [296, 748.0]
    rotation: 0
    state: true
- name: zeromq_pub_sink_0
  id: zeromq_pub_sink
  parameters:
    address: tcp://*:5556
    affinity: ''
    alias: ''
    comment: ''
    hwm: '0'
    key: ''
    pass_tags: 'False'
    timeout: '100'
    type: complex
    vlen: '2'
  states:
    bus_sink: false
    bus_source: false
    bus_structure: null
    coordinate: [1256, 364.0]
    rotation: 0
    state: true
- name: zeromq_sub_source_0
  id: zeromq_sub_source
  parameters:
    address: tcp://127.0.0.1:5555
    affinity: ''
    alias: zeromq_sub_source
    comment: ''
    hwm: '0'
    key: ''
    maxoutbuf: '0'
    minoutbuf: '0'
    pass_tags: 'False'
    timeout: '100'
    type: complex
    vlen: '1'
  states:
    bus_sink: false
    bus_source: false
    bus_structure: null
    coordinate: [312, 260.0]
    rotation: 0
    state: true

connections:
- [blocks_stream_to_vector_0, '0', zeromq_pub_sink_0, '0']
- [control_sawtooth, '0', time_slicer, '0']
- [decimate_clean, '0', file_clean, '0']
- [decimate_jammed, '0', file_jammed, '0']
- [float_to_complex, '0', on_off_switch, '1']
- [interpolator, '0', float_to_complex, '0']
- [mag_sq_clean, '0', decimate_clean, '0']
- [mag_sq_jammed, '0', decimate_jammed, '0']
- [mixer, '0', blocks_stream_to_vector_0, '0']
- [mixer, '0', mag_sq_jammed, '0']
- [on_off_switch, '0', power_scale, '0']
- [power_scale, '0', mixer, '1']
- [rf_source, '0', on_off_switch, '0']
- [time_slicer, '0', interpolator, '0']
- [zeromq_sub_source_0, '0', mag_sq_clean, '0']
- [zeromq_sub_source_0, '0', mixer, '0']

metadata:
  file_format: 1
